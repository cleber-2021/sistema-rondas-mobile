{
  "expo": {
    "name": "Ronda SSI",
    "slug": "sulclean-rondas",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo_fundo_preto.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo_fundo_preto.png",
      "resizeMode": "contain",
      "backgroundColor": "#1e1e1e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sulclean.rondas"
    },
    "android": {
      "package": "com.sulclean.rondas",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo_fundo_preto.png",
        "backgroundColor": "#1e1e1e"
      },
      "edgeToEdgeEnabled": false, 
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "CAMERA",
        "RECORD_AUDIO",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Permita rastrear a sua localização.",
          "locationAlwaysPermission": "Permita rastrear a localização.",
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Permita o acesso à câmara."
        }
      ],
      "expo-notifications",
      "expo-task-manager"
    ]
  }
}