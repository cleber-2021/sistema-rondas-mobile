{
  "expo": {
    "name": "SSI Inspecao",
    "slug": "sulclean-rondas",
    "version": "1.0.43",
    "orientation": "portrait",
    "icon": "./assets/logo_fundo_preto.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo_fundo_preto.png",
      "resizeMode": "contain",
      "backgroundColor": "#1e1e1e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sulclean.rondas"
    },
    "android": {
      "package": "com.sulclean.rondas",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo_fundo_preto.png",
        "backgroundColor": "#1e1e1e"
      },
      "edgeToEdgeEnabled": false,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "CAMERA",
        "RECORD_AUDIO",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "POST_NOTIFICATIONS",
        "USE_FULL_SCREEN_INTENT",
        "SCHEDULE_EXACT_ALARM",
        "USE_EXACT_ALARM",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Permita rastrear a sua localizacao.",
          "locationAlwaysPermission": "Permita rastrear a localizacao.",
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Permita o acesso a camera."
        }
      ],
      [
        "expo-notifications",
        {
          "sounds": [
            "./assets/sirene.mp3"
          ]
        }
      ],
      "expo-task-manager",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "1133828b-f5af-4b0a-81df-1f4ac4f9270e"
      }
    },
    "owner": "clebersulcleans-team"
  }
}
